# ═══════════════════════════════════════════════════════════════
#  Firesky Industries — Production Environment Variables
#  Copy this file to .env in your production server folder
#  and fill in every value before starting the app.
# ═══════════════════════════════════════════════════════════════

# ── Server ───────────────────────────────────────────────────────
# Passenger sets PORT automatically — do NOT set this manually on Afrihost.
# PORT=3000

NODE_ENV=production

# ── Database (PostgreSQL) ────────────────────────────────────────
# Use Afrihost's built-in PostgreSQL (created via cPanel → PostgreSQL Database Wizard).
# Replace cpaneluser, password and dbname with your actual values.
# cPanel prefixes database/username with your account name automatically.
# No SSL needed — it connects over localhost.
DATABASE_URL=postgresql://cpaneluser_fireskyuser:password@localhost/cpaneluser_firesky

# ── Clerk Authentication ─────────────────────────────────────────
# From your Clerk dashboard → API Keys → Production instance
# Use the LIVE keys (pk_live_ and sk_live_), NOT the test keys.
CLERK_PUBLISHABLE_KEY=pk_live_REPLACE_ME
CLERK_SECRET_KEY=sk_live_REPLACE_ME

# ── OpenAI ───────────────────────────────────────────────────────
OPENAI_API_KEY=sk-REPLACE_ME

# ── Resend (email) ───────────────────────────────────────────────
RESEND_API_KEY=re_REPLACE_ME

# ── Web Push Notifications (VAPID) ───────────────────────────────
# Generate once with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=REPLACE_ME
VAPID_PRIVATE_KEY=REPLACE_ME
VAPID_EMAIL=support@fireskyops.tech

# ── Session Secret ────────────────────────────────────────────────
# Any long random string — generate with: openssl rand -hex 32
SESSION_SECRET=REPLACE_ME

# ── Live Data API Key (for Gemini integration) ───────────────────
LIVE_DATA_API_KEY=59834e2a7555d27ae745be2ff242bc9557b122b572e8cddad7ce2ba668b5f8bd

# ── Object Storage (optional — leave blank if not using) ─────────
DEFAULT_OBJECT_STORAGE_BUCKET_ID=
PRIVATE_OBJECT_DIR=
PUBLIC_OBJECT_SEARCH_PATHS=

# ── Gemini (optional) ────────────────────────────────────────────
GEMINI_API_KEY=
